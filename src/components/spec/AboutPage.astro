---
import Highlight from '@/components/Highlight.astro'

interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props

const selfIntroduction = {
  heading: '私について',
  paragraphs: [
    '競技プログラミングなどをやっています。'
  ],
}

const careerItems = [
  {
    year: '2024.04',
    title: '東京工業大学 (現：東京科学大学 理工学系) 情報理工学院 入学',
  },
  {
    year: '2025.04-',
    title: '東京科学大学 理工学系 情報理工学院 数理・計算科学系 所属',
  },
]
---

<div class="max-w-[1100px] mx-auto px-4 md:px-8 py-16 space-y-8" data-pagefind-body>
  <header class="space-y-4 max-w-3xl">
    <h1 class="text-4xl md:text-5xl font-bold leading-tight">
      <Highlight>{title}</Highlight>
    </h1>
    <p class="text-lg leading-8 text-secondary">{description}</p>
  </header>

  <section class="relative overflow-hidden rounded-3xl border border-primary bg-secondary/40 p-6 md:p-8 shadow-sm">
    <div
      class="pointer-events-none absolute inset-0 opacity-80"
      style="background: radial-gradient(circle at top right, rgb(var(--color-accent) / 0.16), transparent 42%), radial-gradient(circle at bottom left, rgb(var(--color-text-primary) / 0.06), transparent 40%);"
    ></div>
    <div class="relative space-y-5">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-accent">Self-Introduction</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight">{selfIntroduction.heading}</h2>
      {
        selfIntroduction.paragraphs.map((paragraph) => (
          <p class="max-w-2xl text-lg leading-8 text-primary">{paragraph}</p>
        ))
      }
    </div>
  </section>

  <section class="relative overflow-hidden rounded-3xl border border-primary bg-secondary/40 p-6 md:p-8 shadow-sm">
    <div
      class="pointer-events-none absolute inset-0 opacity-80"
      style="background: radial-gradient(circle at top left, rgb(var(--color-accent) / 0.10), transparent 35%);"
    ></div>
    <div class="relative space-y-6">
      <div class="space-y-2">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-accent">Career</p>
        <h3 class="text-2xl md:text-3xl font-bold">これまでの流れ</h3>
      </div>

      <ol class="space-y-4 pl-0 list-none">
        {
          careerItems.map((item) => (
            <li class="grid gap-3 md:grid-cols-[7.5rem_minmax(0,1fr)] md:gap-5 md:items-start">
              <p class="inline-flex w-fit items-center rounded-full border border-primary bg-primary/70 px-3 py-1 font-mono text-xs font-bold text-accent">
                {item.year}
              </p>
              <div class="rounded-2xl border border-primary/80 bg-primary/50 px-4 py-4">
                <h4 class="mt-0 text-xl">{item.title}</h4>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</div>